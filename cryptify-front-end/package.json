{
    "name": "pg-filesharing",
    "version": "0.1.0",
    "private": true,
    "main": "./public/electron.js",
    "homepage": "/filesharing/",
    "authors": [
        "Rowan Goemans <rowan.goemans@bdtnl.com>",
        "L. Botros <l.botros@cs.ru.nl>"
    ],
    "build": {
        "appId": "cryptify",
        "files": ["dist/**/*", "./build/*"],
        "dmg": {
            "contents": [
                {
                    "x": 110,
                    "y": 150
                },
                {
                    "x": 240,
                    "y": 150,
                    "type": "link",
                    "path": "/Applications"
                }
            ]
        },
        "linux": {
            "target": ["AppImage", "deb"]
        },
        "win": {
            "category": "Security"
        },
        "directories": {
            "buildResources": "assets"
        },
        "mac": {
            "category": "Utilities"
        }
    },
    "dependencies": {
        "@e4a/pg-wasm": "^0.6.1",
        "@privacybydesign/yivi-client": "^1.0.0",
        "@privacybydesign/yivi-core": "^1.0.0",
        "@privacybydesign/yivi-web": "^1.0.2",
        "@transcend-io/conflux": "^6.1.3",
        "node-polyfill-webpack-plugin": "^4.1.0",
        "react": "^19.2.0",
        "react-device-detect": "^2.2.3",
        "react-dom": "^19.2.0",
        "react-file-drop": "^3.1.6",
        "react-scripts": "^5.0.1",
        "streamsaver": "^2.0.6",
        "web-streams-polyfill": "^4.3.0"
    },
    "scripts": {
        "start": "PORT=8080 craco start",
        "build-stable": "REACT_APP_ENV=stable craco build",
        "build-main": "REACT_APP_ENV=main craco build",
        "dist-electron": "electron-builder",
        "test": "craco test",
        "test:electron": "node --test test/*.test.js",
        "eject": "craco eject"
    },
    "eslintConfig": {
        "extends": "react-app"
    },
    "browserslist": {
        "production": [">0.2%", "not dead", "not op_mini all"],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "@craco/craco": "^7.1.0",
        "@types/node": "^25.9.2",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/streamsaver": "^2.0.5",
        "electron": "^42.4.0",
        "electron-builder": "^26.15.2",
        "electron-reload": "^1.5.0",
        "typescript": "^5.9.3"
    },
    "overrides": {
        "webpack": "^5.107.2",
        "@babel/helpers": "^7.26.10",
        "@babel/runtime": "^7.26.10",
        "@babel/plugin-transform-modules-systemjs": "^7.29.4",
        "ajv@^6.0.0": "^6.14.0",
        "bn.js@^4.0.0": "^4.12.3",
        "brace-expansion@^1.0.0": "^1.1.13",
        "brace-expansion@^2.0.0": "^2.0.3",
        "nth-check": "^2.1.1",
        "postcss": "^8.5.10",
        "resolve-url-loader": "^5.0.0",
        "serialize-javascript": "^7.0.5",
        "@tootallnate/once": "^2.0.1",
        "sockjs": {
            "uuid": "^11.1.1"
        }
    }
}
